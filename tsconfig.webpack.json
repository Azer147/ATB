
{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ESNext", "DOM"],
        "types": [
            "node"
        ],
        "moduleResolution": "NodeNext",
        "module": "NodeNext",
        "esModuleInterop": true,
        "removeComments": true,
        "strict": true,
        "sourceMap": false,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noUncheckedIndexedAccess": true,
        "resolveJsonModule": true,
        "paths": {
            "@/*": ["./*"]
        }
    },
    "include": [
        "webpack.config.ts"
    ]
}
